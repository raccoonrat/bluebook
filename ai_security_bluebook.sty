\newcommand{\bluebooktitle}[1]{\renewcommand{\BBTitle}{#1}}
\newcommand{\bluebooksubtitle}[1]{\renewcommand{\BBSubtitle}{#1}}
\newcommand{\bluebookauthor}[1]{\renewcommand{\BBAuthor}{#1}}
\newcommand{\bluebookorg}[1]{\renewcommand{\BBOrg}{#1}}
