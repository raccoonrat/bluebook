
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{ai_security_bluebook}[2026/04/23 v1.0 AI Security Bluebook Style]

% =============================
% Engine / basic packages
% =============================
\RequirePackage{iftex}
\RequirePackage{xcolor}
\RequirePackage{geometry}
\RequirePackage{setspace}
\RequirePackage{titlesec}
\RequirePackage{titling}
\RequirePackage{fancyhdr}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{enumitem}
\RequirePackage{hyperref}
\RequirePackage{bookmark}
\RequirePackage{amsmath,amssymb,amsthm,mathtools}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{etoolbox}
\RequirePackage{caption}
\RequirePackage{tocloft}
\RequirePackage{titlesec}
\RequirePackage{needspace}
\RequirePackage{multicol}
\RequirePackage{pgffor}
\RequirePackage{kvoptions}

\ifPDFTeX
  \PackageWarning{ai_security_bluebook}{PDFLaTeX detected. For bilingual Chinese/English bluebook output, XeLaTeX is recommended.}
\fi
\ifXeTeX
  \RequirePackage{fontspec}
  \RequirePackage{xeCJK}
  \defaultfontfeatures{Ligatures=TeX}
  \setmainfont{TeX Gyre Termes}
  \setsansfont{TeX Gyre Heros}
  \setmonofont{Latin Modern Mono}
  % Prefer Noto CJK when available; fall back to Fandol on TeXLive-full.
  \IfFontExistsTF{Noto Serif CJK SC}{\setCJKmainfont{Noto Serif CJK SC}}{\setCJKmainfont{FandolSong-Regular}}
  \IfFontExistsTF{Noto Sans CJK SC}{\setCJKsansfont{Noto Sans CJK SC}}{\setCJKsansfont{FandolHei-Regular}}
  \IfFontExistsTF{Noto Sans Mono CJK SC}{\setCJKmonofont{Noto Sans Mono CJK SC}}{\setCJKmonofont{FandolFang-Regular}}
\fi
\ifLuaTeX
  \RequirePackage{fontspec}
  \defaultfontfeatures{Ligatures=TeX}
  \setmainfont{TeX Gyre Termes}
  \setsansfont{TeX Gyre Heros}
  \setmonofont{Latin Modern Mono}
\fi

% =============================
% Layout
% =============================
\geometry{a4paper,margin=1in,headheight=16pt,footskip=28pt}
\setstretch{1.12}
\setlength{\parskip}{0.35em}
\setlength{\parindent}{2em}
\captionsetup{font=small,labelfont=bf}
\setlist[itemize]{leftmargin=1.8em,itemsep=0.25em,topsep=0.35em}
\setlist[enumerate]{leftmargin=2.2em,itemsep=0.25em,topsep=0.35em}
\renewcommand{\arraystretch}{1.25}

% =============================
% Colors
% =============================
\definecolor{BBPrimary}{HTML}{0A4FA3}
\definecolor{BBSecondary}{HTML}{2F6FB6}
\definecolor{BBAccent}{HTML}{00A3A3}
\definecolor{BBText}{HTML}{1C2430}
\definecolor{BBMuted}{HTML}{5B6677}
\definecolor{BBLine}{HTML}{D9E2F0}
\definecolor{BBSoft}{HTML}{F4F8FC}
\definecolor{BBWarn}{HTML}{A35A00}
\definecolor{BBDanger}{HTML}{A31E1E}
\definecolor{BBGood}{HTML}{1E7A37}

\color{BBText}

% =============================
% Hyperref
% =============================
\hypersetup{
  colorlinks=true,
  linkcolor=BBPrimary,
  urlcolor=BBSecondary,
  citecolor=BBAccent,
  pdftitle={AI Security Bluebook},
  pdfauthor={},
  pdfsubject={Unified AI Security Control Plane / Decoupled Safety / Evaluation Framework},
  pdfkeywords={AI Security, Control Plane, Decoupled Safety, Evaluation Framework}
}

% =============================
% Metadata commands
