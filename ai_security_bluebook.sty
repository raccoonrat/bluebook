\newenvironment{systemassumptions}{\Needspace{6\baselineskip}\subsection*{Assumptions and Constraints}}{}
\newenvironment{evaluationcriteria}{\Needspace{6\baselineskip}\subsection*{Evaluation Criteria}}{}
\newenvironment{operationalnotes}{\Needspace{6\baselineskip}\subsection*{Operational Notes}}{}
\newenvironment{researchquestions}{\Needspace{6\baselineskip}\subsection*{Open Research Questions}}{}

