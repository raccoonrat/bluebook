% =============================
% Title page
% =============================
\newcommand{\makebluebookcover}{%
  \begin{titlepage}
    \thispagestyle{empty}
    \noindent
    {\Large\bfseries\color{BBPrimary} Technical Bluebook}\par
    \vspace{1.3cm}

    {\fontsize{26}{32}\selectfont\bfseries \BBTitle\par}
    \vspace{0.35cm}
    {\Large\color{BBMuted}\BBSubtitle\par}
    \vspace{1.0cm}

    \begin{tcolorbox}[
      enhanced,
      colback=BBSoft,
      colframe=BBPrimary,
      boxrule=0.6pt,
      arc=2mm,
      left=6pt,right=6pt,top=6pt,bottom=6pt]
      \textbf{Scope.} Unified AI Security Control Plane \quad $\bullet$ \quad Decoupled Safety \quad $\bullet$ \quad Evaluation Framework

      \vspace{0.35em}
      \textbf{Purpose.} Establish a rigorous, enterprise-grade technical blueprint for controllable, auditable, and evolvable AI security.
    \end{tcolorbox}

    \vfill

    \begin{tabular}{@{}p{0.22\textwidth}p{0.72\textwidth}@{}}
      \textbf{Author(s)} & \BBAuthor \\
      \textbf{Organization} & \BBOrg \\
      \textbf{Version} & \BBVersion \\
      \textbf{Date} & \BBDate \\
      \textbf{Classification} & \BBClassification \\
      \textbf{Keywords} & \BBKeywords \\
    \end{tabular}

    \vspace{1.2cm}
    {\small\color{BBMuted}\BBCoverNote\par}
  \end{titlepage}
}

% =============================
% Page style
% =============================
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\textcolor{BBMuted}{\nouppercase{\leftmark}}}
\fancyhead[R]{\textcolor{BBMuted}{AI Security Bluebook}}
\fancyfoot[C]{\textcolor{BBMuted}{\thepage}}
\renewcommand{\headrulewidth}{0.25pt}
\renewcommand{\footrulewidth}{0pt}

% =============================
% Chapter / section formatting
% =============================
\titleformat{\chapter}[display]
  {\normalfont\bfseries}
  {\color{BBPrimary}\Large Chapter \thechapter}
  {0.2em}
  {\Huge\color{BBText}}
  [\vspace{0.3em}\titlerule\vspace{0.6em}]

\titleformat{\section}
  {\Large\bfseries\color{BBPrimary}}
  {\thesection}
  {0.6em}
  {}

\titleformat{\subsection}
  {\large\bfseries\color{BBText}}
  {\thesubsection}
  {0.6em}
  {}

\titleformat{\subsubsection}
  {\normalsize\bfseries\color{BBText}}
  {\thesubsubsection}
  {0.6em}
  {}

\titlespacing*{\chapter}{0pt}{0pt}{1.2em}
\titlespacing*{\section}{0pt}{1.0em}{0.5em}
\titlespacing*{\subsection}{0pt}{0.85em}{0.4em}

% TOC style
\renewcommand{\cftchapfont}{\bfseries}
\renewcommand{\cftsecfont}{}
\renewcommand{\cftchappagefont}{\bfseries}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}

% =============================
% Theorem-like environments
% =============================
\newtheorem{theorem}{Theorem}[chapter]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{assumption}[theorem]{Assumption}
\newtheorem{property}[theorem]{Property}
\newtheorem{invariant}[theorem]{Invariant}
\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
\newtheorem{example}[theorem]{Example}

% =============================
% Boxes and custom environments
% =============================
\tcbset{enhanced,breakable,boxrule=0.55pt,arc=2mm,left=6pt,right=6pt,top=6pt,bottom=6pt}

\newtcolorbox{executivesummarybox}{colback=BBSoft,colframe=BBPrimary,title=Executive Summary,fonttitle=\bfseries}
\newtcolorbox{keymessagebox}{colback=BBSoft,colframe=BBSecondary,title=Key Message,fonttitle=\bfseries}
\newtcolorbox{designprinciplebox}{colback=white,colframe=BBAccent,title=Design Principle,fonttitle=\bfseries}
\newtcolorbox{riskbox}{colback=white,colframe=BBDanger,title=Risk / Threat,fonttitle=\bfseries}
\newtcolorbox{evaluationbox}{colback=white,colframe=BBGood,title=Evaluation / Assurance,fonttitle=\bfseries}
\newtcolorbox{researchbox}{colback=white,colframe=BBWarn,title=Open Problem / Research Agenda,fonttitle=\bfseries}
\newtcolorbox{takeawaybox}{colback=BBSoft,colframe=BBPrimary,title=Key Takeaway,fonttitle=\bfseries}

\newcommand{\executivesummary}[1]{\begin{executivesummarybox}#1\end{executivesummarybox}}
\newcommand{\keymessage}[1]{\begin{keymessagebox}#1\end{keymessagebox}}
\newcommand{\designprinciple}[2]{\begin{designprinciplebox}\textbf{#1}. #2\end{designprinciplebox}}
\newcommand{\securityrisk}[2]{\begin{riskbox}\textbf{#1}. #2\end{riskbox}}
\newcommand{\evaluationnote}[2]{\begin{evaluationbox}\textbf{#1}. #2\end{evaluationbox}}
\newcommand{\researchagenda}[2]{\begin{researchbox}\textbf{#1}. #2\end{researchbox}}
\newcommand{\keytakeaway}[1]{\begin{takeawaybox}#1\end{takeawaybox}}

\newenvironment{chapterobjective}{\begin{tcolorbox}[colback=BBSoft,colframe=BBLine,title=Chapter Objective,fonttitle=\bfseries]}{\end{tcolorbox}}
\newenvironment{chapterboundary}{\begin{tcolorbox}[colback=white,colframe=BBLine,title=System Boundary,fonttitle=\bfseries]}{\end{tcolorbox}}
\newenvironment{chapterdeliverables}{\begin{tcolorbox}[colback=white,colframe=BBLine,title=Deliverables,fonttitle=\bfseries]}{\end{tcolorbox}}

% =============================
% Reusable list macros
% =============================
\newcommand{\bluebookbullet}[1]{\item \textbf{#1}}
\newcommand{\term}[1]{\textbf{#1}}
\newcommand{\TODO}[1]{\textcolor{BBDanger}{[TODO: #1]}}

